# Copy to .env and fill in real values. Never commit .env.

# --- LLM (required for agent routes) ---
OPENAI_API_KEY=sk-proj-your-key-here

# Optional: other providers
# GOOGLE_API_KEY=

# --- Supabase (required) ---
# Dashboard → Project Settings → API
SUPABASE_PROJECT_URL=https://YOUR_PROJECT_REF.supabase.co
# Optional newer key name; app may use anon below
SUPABASE_PUBLISHABLE_KEY=
# Settings → API → anon public
SUPABASE_ANNON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.replace-with-anon-jwt
# Settings → API → service_role (server only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.replace-with-service-role-jwt

# Database: Project Settings → Database → Connection string
# Use the pooler URI for the app + Prisma (often port 6543, add ?pgbouncer=true if shown)
SUPABASE_DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct / session connection for migrations (often port 5432, not pgbouncer)
SUPABASE_DIRECT_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# --- Supabase Storage (file uploads) ---
# Create this bucket in Storage → New bucket (name must match)
OBJECTS_STORAGE_BUCKET=app-object-storage
OBJECTS_STORAGE_BASE_PATH=projects

# Optional: S3-compatible endpoint instead of Supabase URL (advanced)
# OBJECTS_STORAGE_ENDPOINT=
# OBJECTS_STORAGE_ROOT_USER=
# OBJECTS_STORAGE_ROOT_PASSWORD=

# --- Dev only: ClickUp smoke route (do not use real tokens in committed files) ---
# CLICKUP_SMOKE_TOKEN=
# CLICKUP_SMOKE_LIST_URL=
