generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("SUPABASE_DATABASE_URL")
  directUrl = env("SUPABASE_DIRECT_URL")
}

enum TestcaseResult {
  fail
  success
}

enum TestcaseStatus {
  running
  completed
}

enum TestcasePriority {
  low
  medium
  high
}

enum ProviderType {
  github
  clickup
  jira
}

model User {
  user_id       Int      @id @default(autoincrement())
  user_name     String?
  user_email    String?  @unique
  user_password String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  projects  Project[]
  providers Provider[]
}

/// One row per (user, provider_type): e.g. at most one GitHub, one ClickUp, one Jira per user.
// provider_config
// 1. clickup
// {
//   "list_id": "<id>",
//   "list_url": "https://app.clickup.com/<id>/v/li/<...>"
// }
// 2. github
// { "repo": "owner/repository" }
// 3. jira
// { "site_url": "https://your.atlassian.net", "email": "you@co.com", "project_key": "PROJ" } (API token in `provider_api_key`)
model Provider {
  provider_id      Int          @id @default(autoincrement())
  user_id          Int
  provider_type    ProviderType
  provider_api_key String?
  provider_config  Json?
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([user_id, provider_type])
}

model Project {
  project_id          Int      @id @default(autoincrement())
  user_id             Int
  project_name        String
  project_thumbnail   String?
  project_description String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  user  User   @relation(fields: [user_id], references: [user_id])
  tests Test[]
}

model Test {
  test_id               Int            @id @default(autoincrement())
  project_id            Int
  test_name             String
  test_status           TestcaseStatus @default(running)
  test_url              String?
  test_source_reference String?
  test_documentation    String?
  start_time            DateTime       @default(now())
  end_time              DateTime?

  project       Project       @relation(fields: [project_id], references: [project_id])
  testcases     Testcase[]
  testSummaries TestSummary[]
}

/// One row per generated PDF summary stored in object storage (many per test over time).
model TestSummary {
  id           Int      @id @default(autoincrement())
  test_id      Int
  test_summary String
  created_at   DateTime @default(now())

  test Test @relation(fields: [test_id], references: [test_id], onDelete: Cascade)

  @@map("Test_Summary")
}

model Testcase {
  testcase_id           Int              @id @default(autoincrement())
  test_id               Int
  testcase_unique_id    String?
  testcase_name         String
  testcase_description  String?
  testcase_script       String?
  testcase_result       TestcaseResult   @default(fail)
  testcase_status       TestcaseStatus   @default(running)
  testcase_video        String?
  testcase_type         String?
  testcase_category     String?
  testcase_piority      TestcasePriority @default(low)
  testcase_suggestion   String?
  testcase_console_logs String?
  testcase_network_logs String?
  testcase_metadata     String?
  created_at            DateTime         @default(now())

  test Test @relation(fields: [test_id], references: [test_id])
}
